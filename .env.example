# ---------------------------------------------------------------------------
# PolyGraphRAG configuration. Copy to `.env` and fill in the values.
#   cp .env.example .env
# `.env` is gitignored — never commit real keys.
# ---------------------------------------------------------------------------

# === Postgres ==============================================================
# POSTGRES_PASSWORD is required (compose refuses to start without it).
POSTGRES_PASSWORD=change-me
POSTGRES_DB=ragdb
POSTGRES_USER=raguser
POSTGRES_PORT=5432
# NOTE: do not set POSTGRES_WORKSPACE — it would make LightRAG collapse every
# workspace onto one graph and break multi-project isolation (see docker-compose.yml).

# Host port the API listens on (loopback only).
RAG_PORT=9622

# === API auth (opt-in) =====================================================
# Comma-separated API tokens. Blank => NO auth (safe only while loopback-bound).
# When exposing the service to a network, set at least one token AND serve over TLS
# (a bearer token over plain HTTP is sent in the clear).
#   Machines: send `Authorization: Bearer <token>`.
#   Browsers (/docs, graph.html): any username + the token as the password.
# Every endpoint except /health is gated. NOTE: this is a single-instance, low-usage
# service — run exactly one worker/replica (ingest job state is in-process); it is not
# designed for high load or horizontal scaling.
API_TOKENS=

# Log verbosity: DEBUG | INFO (default) | WARNING | ERROR. DEBUG makes LightRAG /
# RAG-Anything log prompt + document content — keep at INFO in normal operation.
LOG_LEVEL=INFO

# === Model providers =======================================================
# Every model role is independently routable to OpenAI OR any OpenAI-compatible
# endpoint (OpenRouter, DeepSeek, Ollama, vLLM, LM Studio, TEI, ...).
# Rule for each role:
#   <ROLE>_BASE_URL empty  -> OpenAI, authenticated with OPENAI_API_KEY
#   <ROLE>_BASE_URL set    -> that endpoint, authed with <ROLE>_API_KEY
#                             (falls back to OPENAI_API_KEY if left blank)

# Fallback key used by any role whose own *_API_KEY is blank.
OPENAI_API_KEY=

# --- Text LLM: entity/relationship extraction at ingest time (high volume) --
LLM_MODEL=gpt-5.4-mini
LLM_BASE_URL=
LLM_API_KEY=

# --- Text LLM: query-time keyword extraction + answer synthesis -------------
# Latency-sensitive. Leave any QUERY_* blank to reuse the extraction LLM above.
QUERY_LLM_MODEL=
QUERY_LLM_BASE_URL=
QUERY_LLM_API_KEY=

# --- Embeddings (pgvector) --------------------------------------------------
# NOTE: EMBEDDING_MODEL + EMBEDDING_DIM name the vector tables. Changing them
# points at NEW empty tables — the corpus must be re-ingested. Keep them stable.
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536
EMBEDDING_BASE_URL=
EMBEDDING_API_KEY=

# --- Vision: PDF/image content extraction (must be a MULTIMODAL model) ------
VISION_MODEL=gpt-5.4-mini
VISION_BASE_URL=
VISION_API_KEY=

# --- Whisper: audio transcription (OpenAI /v1/audio/transcriptions shape) ---
WHISPER_MODEL=whisper-1
WHISPER_BASE_URL=
WHISPER_API_KEY=

# === Behavior ==============================================================
MAX_RETRIES=5
# Treat an ingest as failed if a non-trivial doc produces zero graph entities.
RAG_REQUIRE_GRAPH_EXTRACTION=true

# ---------------------------------------------------------------------------
# Worked example — cost-optimized: DeepSeek (via OpenRouter) for the text LLM,
# OpenAI for embeddings only. Cheap high-volume extraction, high-quality vectors.
# Copy these over the blanks above to use it:
#
#   LLM_MODEL=deepseek/deepseek-chat
#   LLM_BASE_URL=https://openrouter.ai/api/v1
#   LLM_API_KEY=sk-or-...                 # your OpenRouter key
#   EMBEDDING_MODEL=text-embedding-3-small
#   EMBEDDING_BASE_URL=                   # blank -> OpenAI
#   OPENAI_API_KEY=sk-...                 # used for embeddings (and vision, if PDFs/images)
#
# (DeepSeek's own endpoint works too: LLM_BASE_URL=https://api.deepseek.com,
#  LLM_MODEL=deepseek-chat, LLM_API_KEY=<deepseek key>.)
# ---------------------------------------------------------------------------
